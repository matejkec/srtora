# SRTora Environment Configuration
# Copy this file to .env.local and customize as needed.

# ============================================
# Local Provider Defaults
# ============================================
# These are used as default endpoint URLs in the UI.
# No changes needed for standard setups.

# OLLAMA_BASE_URL=http://localhost:11434
# MLX_BASE_URL=http://localhost:8080

# ============================================
# Cloud Provider API Keys (optional)
# ============================================
# API keys are session-scoped in the UI by default.
# Setting them here provides defaults for convenience.
# These are NEVER logged or persisted beyond the process.

# OPENAI_API_KEY=sk-...
# GOOGLE_AI_API_KEY=...
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# Anthropic CORS Proxy (optional)
# ============================================
# Anthropic's API does not support CORS from browsers.
# If using Anthropic, run a CORS proxy and set its URL here.
# ANTHROPIC_PROXY_URL=http://localhost:8787
